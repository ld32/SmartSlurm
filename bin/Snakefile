configfile: "config.yaml"

NUMBERS = ["1"]
NUMBER = ['1234', '5678']

rule all:
    input:
        "all.txt"

rule find_number:
    input:
        "numbers{NUMBERS}.txt"
    output:
        "{NUMBER}.{NUMBERS}.txt"
    shell:
        "findNumber.sh {wildcards.NUMBER} {input} > {output}"

rule merge:
    input:
        "1234.1.txt", 
        '5678.1.txt'
    output:
        "all.txt"
    shell:
        "cat {input} > {output}"
